{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "{{python}} {{repo_root}}/src/codex_click_chooser_hooks/hooks/session_start_request_user_input_policy.py",
            "statusMessage": "Loading chooser policy (codex-click-chooser-hooks)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{python}} {{repo_root}}/src/codex_click_chooser_hooks/hooks/stop_require_request_user_input.py",
            "statusMessage": "Checking next-step chooser (codex-click-chooser-hooks)"
          }
        ]
      }
    ]
  }
}
